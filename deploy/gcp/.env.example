COMPOSE_PROJECT_NAME=input_surat
PUBLIC_ORIGIN=https://input-surat.vercel.app
GATEWAY_PORT=18082

APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

DB_DATABASE=/var/www/html/database/runtime/database.sqlite
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@input-surat.local
ADMIN_PASSWORD=change-me-now
